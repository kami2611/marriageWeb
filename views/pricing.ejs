  <!-- FAQ Schema for pricing page -->
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "What does 'on match' mean in D'amour Muslim pricing?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "For Premium Plus and Executive plans, you pay an initial fee to join. The 'on match' fee is only charged when we successfully introduce you to someone and both parties agree to proceed with the proposal."
          }
        },
        {
          "@type": "Question",
          "name": "Can I upgrade my D'amour Muslim plan later?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes! You can upgrade from any plan at any time. Contact us and we'll help you move to a higher tier and unlock additional features."
          }
        },
        {
          "@type": "Question",
          "name": "How much does Muslim matchmaking cost in the UK?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "D'amour Muslim offers a free Standard plan. Paid plans start from £50 (Premium) for profile sharing across 10+ WhatsApp groups, £100 (Premium Plus) for curated weekly matches, and £150 (Executive) for fully managed matchmaking. All paid plans include a 100% money-back guarantee."
          }
        },
        {
          "@type": "Question",
          "name": "Does D'amour Muslim offer a money-back guarantee?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes. D'amour Muslim offers a 100% money-back guarantee within the first 15 days — no questions asked. After that, refunds are available if we fail to deliver the committed services."
          }
        },
        {
          "@type": "Question",
          "name": "Is D'amour Muslim free to use?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes, the Standard plan is completely free. You can create a profile, browse all profiles on the website and in WhatsApp groups, and connect directly. Premium features are available from £50."
          }
        }
      ]
    }
  </script>

