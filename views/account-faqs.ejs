<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Account FAQs - D'amour Muslim | Help & Support</title>
  <meta name="description" content="Frequently asked questions about D'amour Muslim accounts. Learn about sending requests, chatting, profile management, and how our Muslim matrimony platform works.">
  <meta name="keywords" content="D'amour Muslim FAQ, account help, matrimony questions, profile management, how to send requests, Muslim marriage platform help">
  
  <!-- Open Graph / Social Media -->
  <meta property="og:title" content="Account FAQs - D'amour Muslim">
  <meta property="og:description" content="Get answers to common questions about your D'amour Muslim account, requests, chatting, and profile management.">
  <meta property="og:type" content="website">
  <meta property="og:url" content="https://damourmuslim.com/account-faqs">

  <!-- Tailwind CSS -->
  <link rel="stylesheet" href="/css/output.css">
  <!-- Remix Icons -->
  <link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet">

  <!-- Custom CSS -->
  <link rel="stylesheet" href="/css/style.css">

  <style>
    .faq-item {
      cursor: pointer;
      transition: all 0.3s ease;
    }
    .faq-item:hover {
      background-color: #f9fafb;
    }
    .faq-answer {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.3s ease-out, padding 0.3s ease;
    }
    .faq-item.active .faq-answer {
      max-height: 1000px;
      padding-top: 1rem;
    }
    .faq-item.active .faq-icon {
      transform: rotate(180deg);
    }
    .faq-icon {
      transition: transform 0.3s ease;
    }
    .category-tab {
      transition: all 0.2s ease;
    }
    .category-tab.active {
      background-color: #4a7c59;
      color: white;
    }
  </style>
</head>

<body class="bg-gray-50 font-['Roboto']">
  <%- include('partials/header') %>

  <main class="pt-24 pb-16 min-h-screen">
    <div class="max-w-4xl mx-auto px-6">
      <!-- Header Section -->
      <div class="text-center mb-8">
        <h1 class="text-4xl font-bold text-gray-900 mb-4 font-['Playfair_Display']">Account FAQs</h1>
        <p class="text-gray-600 text-lg">Frequently Asked Questions About Your Account</p>
        <p class="text-gray-500 mt-2">Find answers to common questions about using D'amour Muslim</p>
      </div>

      <!-- Quick Help Box -->
      <div class="bg-gradient-to-r from-[#4a7c59] to-[#2d5a3a] rounded-2xl p-6 text-white mb-8 shadow-lg">
        <div class="flex items-center justify-between flex-wrap gap-4">
          <div>
            <h2 class="text-xl font-semibold mb-1">Can't find what you're looking for?</h2>
            <p class="text-white/80">Our support team is here to help you</p>
          </div>
          <a href="mailto:contact@damourmuslim.com" class="inline-flex items-center px-5 py-2.5 bg-white text-[#4a7c59] rounded-full font-medium hover:bg-gray-100 transition-colors">
            <i class="ri-mail-line mr-2"></i>
            Contact Support
          </a>
        </div>
      </div>

      <!-- Category Tabs -->
      <div class="flex flex-wrap gap-2 mb-6">
        <button onclick="showCategory('all')" class="category-tab active px-4 py-2 rounded-full text-sm font-medium bg-gray-200 text-gray-700">
          All Questions
        </button>
        <button onclick="showCategory('getting-started')" class="category-tab px-4 py-2 rounded-full text-sm font-medium bg-gray-200 text-gray-700">
          <i class="ri-play-circle-line mr-1"></i>
          Getting Started
        </button>
        <button onclick="showCategory('requests')" class="category-tab px-4 py-2 rounded-full text-sm font-medium bg-gray-200 text-gray-700">
          <i class="ri-send-plane-line mr-1"></i>
          Requests
        </button>
        <button onclick="showCategory('chatting')" class="category-tab px-4 py-2 rounded-full text-sm font-medium bg-gray-200 text-gray-700">
          <i class="ri-chat-3-line mr-1"></i>
          Chatting
        </button>
        <button onclick="showCategory('profile')" class="category-tab px-4 py-2 rounded-full text-sm font-medium bg-gray-200 text-gray-700">
          <i class="ri-user-settings-line mr-1"></i>
          Profile
        </button>
        <button onclick="showCategory('membership')" class="category-tab px-4 py-2 rounded-full text-sm font-medium bg-gray-200 text-gray-700">
          <i class="ri-vip-crown-line mr-1"></i>
          Membership
        </button>
      </div>

      <!-- Main Content -->
      <div class="bg-white rounded-2xl material-shadow overflow-hidden">
        
        <!-- GETTING STARTED SECTION -->
        <div class="p-6 border-b border-gray-100">
          <h2 class="text-xl font-bold text-gray-900 font-['Playfair_Display'] flex items-center">
            <i class="ri-play-circle-fill text-[#4a7c59] mr-2"></i>
            Getting Started
          </h2>
        </div>

        <div class="divide-y divide-gray-100" data-category="getting-started">
          <!-- FAQ Item 1 -->
          <div class="faq-item p-6" onclick="toggleFaq(this)">
            <div class="flex items-start justify-between">
              <h3 class="text-lg font-medium text-gray-900 pr-4">How do I create an account on D'amour Muslim?</h3>
              <i class="ri-arrow-down-s-line faq-icon text-gray-400 text-xl flex-shrink-0"></i>
            </div>
            <div class="faq-answer text-gray-600">
              <p class="mb-3">Creating an account is simple and free:</p>
              <ol class="list-decimal list-inside space-y-2 ml-2">
                <li>Click on <strong>"Register"</strong> in the navigation menu</li>
                <li>Enter your email address and create a password</li>
                <li>Verify your email with the code sent to you</li>
                <li>Complete your profile with accurate information about yourself or your child</li>
                <li>Add a profile photo (optional but recommended)</li>
                <li>Your profile will be reviewed and approved by our team</li>
              </ol>
              <p class="mt-3 text-sm text-gray-500">
                <i class="ri-information-line mr-1"></i>
                Note: Profiles are created by parents/guardians on behalf of their children seeking marriage.
              </p>
            </div>
          </div>

          <!-- FAQ Item 2 -->
          <div class="faq-item p-6" onclick="toggleFaq(this)">
            <div class="flex items-start justify-between">
              <h3 class="text-lg font-medium text-gray-900 pr-4">Do I need to log in to view profiles?</h3>
              <i class="ri-arrow-down-s-line faq-icon text-gray-400 text-xl flex-shrink-0"></i>
            </div>
            <div class="faq-answer text-gray-600">
              <p class="mb-3">You can browse profiles without logging in, but to interact with them, you'll need an account:</p>
              <ul class="list-disc list-inside space-y-2 ml-2">
                <li><strong>Without login:</strong> View basic profile information and photos</li>
                <li><strong>With login:</strong> Send interest requests, chat with matches, and access full profile details</li>
              </ul>
              <p class="mt-3">We recommend creating an account to get the full experience of our platform.</p>
            </div>
          </div>

          <!-- FAQ Item 3 -->
          <div class="faq-item p-6" onclick="toggleFaq(this)">
            <div class="flex items-start justify-between">
              <h3 class="text-lg font-medium text-gray-900 pr-4">Is my profile visible to everyone immediately after registration?</h3>
              <i class="ri-arrow-down-s-line faq-icon text-gray-400 text-xl flex-shrink-0"></i>
            </div>
            <div class="faq-answer text-gray-600">
              <p class="mb-3">No, your profile goes through an approval process:</p>
              <ol class="list-decimal list-inside space-y-2 ml-2">
                <li>After completing registration, your profile is submitted for review</li>
                <li>Our team verifies the information for authenticity and appropriateness</li>
                <li>Once approved, your profile becomes visible to other users</li>
                <li>You'll receive an email notification when your profile is approved</li>
              </ol>
              <p class="mt-3 text-sm text-gray-500">
                This process typically takes 24-48 hours and helps maintain the quality and safety of our community.
              </p>
            </div>
          </div>
        </div>

        <!-- REQUESTS SECTION -->
        <div class="p-6 border-b border-t border-gray-100 bg-gray-50">
          <h2 class="text-xl font-bold text-gray-900 font-['Playfair_Display'] flex items-center">
            <i class="ri-send-plane-fill text-[#4a7c59] mr-2"></i>
            Sending & Receiving Requests
          </h2>
        </div>

        <div class="divide-y divide-gray-100" data-category="requests">
          <!-- FAQ Item 4 -->
          <div class="faq-item p-6" onclick="toggleFaq(this)">
            <div class="flex items-start justify-between">
              <h3 class="text-lg font-medium text-gray-900 pr-4">How do I send an interest request to someone?</h3>
              <i class="ri-arrow-down-s-line faq-icon text-gray-400 text-xl flex-shrink-0"></i>
            </div>
            <div class="faq-answer text-gray-600">
              <p class="mb-3">To send an interest request:</p>
              <ol class="list-decimal list-inside space-y-2 ml-2">
                <li>Log in to your account</li>
                <li>Browse profiles or use filters to find potential matches</li>
                <li>Visit the profile you're interested in</li>
                <li>Click the <strong>"Send Interest"</strong> or <strong>"Express Interest"</strong> button</li>
                <li>Your request will be sent, and the other person will be notified</li>
              </ol>
              <div class="mt-4 p-3 bg-amber-50 rounded-lg">
                <p class="text-amber-800 text-sm">
                  <i class="ri-alert-line mr-1"></i>
                  <strong>Important:</strong> You can only have up to <strong>5 pending requests</strong> at any time. Wait for responses or cancel existing requests to send new ones.
                </p>
              </div>
            </div>
          </div>

          <!-- FAQ Item 5 -->
          <div class="faq-item p-6" onclick="toggleFaq(this)">
            <div class="flex items-start justify-between">
              <h3 class="text-lg font-medium text-gray-900 pr-4">What information is shared when I send a request?</h3>
              <i class="ri-arrow-down-s-line faq-icon text-gray-400 text-xl flex-shrink-0"></i>
            </div>
            <div class="faq-answer text-gray-600">
              <p class="mb-3">When you send an interest request, the receiver can see:</p>
              <ul class="list-disc list-inside space-y-2 ml-2">
                <li>Your profile information (name, age, education, occupation, etc.)</li>
                <li>Your profile photo (if uploaded)</li>
                <li>Your location and other profile details</li>
              </ul>
              <div class="mt-4 p-3 bg-green-50 rounded-lg">
                <p class="text-green-800 text-sm">
                  <i class="ri-shield-check-line mr-1"></i>
                  <strong>Privacy Protected:</strong> Your phone number and personal contact details are <strong>NOT shared</strong> with the request. Contact information is only shared after mutual acceptance.
                </p>
              </div>
            </div>
          </div>

          <!-- FAQ Item 6 -->
          <div class="faq-item p-6" onclick="toggleFaq(this)">
            <div class="flex items-start justify-between">
              <h3 class="text-lg font-medium text-gray-900 pr-4">What happens when someone accepts my request?</h3>
              <i class="ri-arrow-down-s-line faq-icon text-gray-400 text-xl flex-shrink-0"></i>
            </div>
            <div class="faq-answer text-gray-600">
              <p class="mb-3">When your request is accepted:</p>
              <ol class="list-decimal list-inside space-y-2 ml-2">
                <li>You'll receive a notification that your request was accepted</li>
                <li>The other person's profile information is shared back with you</li>
                <li>A chat conversation is automatically created between you</li>
                <li>Both parties can now message each other directly on the platform</li>
                <li>You can view each other's full profile details</li>
              </ol>
              <p class="mt-3 text-gray-500 text-sm">
                This mutual acceptance ensures that both parties are interested before any communication begins.
              </p>
            </div>
          </div>

          <!-- FAQ Item 7 -->
          <div class="faq-item p-6" onclick="toggleFaq(this)">
            <div class="flex items-start justify-between">
              <h3 class="text-lg font-medium text-gray-900 pr-4">Can I cancel a pending request?</h3>
              <i class="ri-arrow-down-s-line faq-icon text-gray-400 text-xl flex-shrink-0"></i>
            </div>
            <div class="faq-answer text-gray-600">
              <p class="mb-3">Yes, you can cancel a pending request at any time:</p>
              <ol class="list-decimal list-inside space-y-2 ml-2">
                <li>Go to your <strong>"Sent Requests"</strong> section in your account</li>
                <li>Find the pending request you wish to cancel</li>
                <li>Click <strong>"Cancel Request"</strong></li>
                <li>The request will be removed, and the other person will no longer see it</li>
              </ol>
              <p class="mt-3">Cancelling a request frees up one of your 5 pending request slots.</p>
            </div>
          </div>

          <!-- FAQ Item 8 -->
          <div class="faq-item p-6" onclick="toggleFaq(this)">
            <div class="flex items-start justify-between">
              <h3 class="text-lg font-medium text-gray-900 pr-4">Can I revoke access after accepting a request?</h3>
              <i class="ri-arrow-down-s-line faq-icon text-gray-400 text-xl flex-shrink-0"></i>
            </div>
            <div class="faq-answer text-gray-600">
              <p class="mb-3">Yes, you have control over your connections:</p>
              <ul class="list-disc list-inside space-y-2 ml-2">
                <li>Go to your <strong>"Accepted Requests"</strong> or <strong>"Connections"</strong> section</li>
                <li>Find the connection you wish to revoke</li>
                <li>Click <strong>"Revoke Access"</strong></li>
                <li>The other person will no longer be able to view your full profile or message you</li>
              </ul>
              <p class="mt-3 text-sm text-gray-500">
                <i class="ri-information-line mr-1"></i>
                This feature allows you to manage your connections and maintain control over who can contact you.
              </p>
            </div>
          </div>

          <!-- FAQ Item 9 -->
          <div class="faq-item p-6" onclick="toggleFaq(this)">
            <div class="flex items-start justify-between">
              <h3 class="text-lg font-medium text-gray-900 pr-4">Why can I only send 5 pending requests?</h3>
              <i class="ri-arrow-down-s-line faq-icon text-gray-400 text-xl flex-shrink-0"></i>
            </div>
            <div class="faq-answer text-gray-600">
              <p class="mb-3">The 5-request limit is designed to:</p>
              <ul class="list-disc list-inside space-y-2 ml-2">
                <li><strong>Encourage thoughtful engagement:</strong> Focus on profiles you're genuinely interested in</li>
                <li><strong>Prevent spam:</strong> Protect users from receiving excessive unwanted requests</li>
                <li><strong>Maintain quality:</strong> Ensure serious users who take time to review profiles</li>
                <li><strong>Fair experience:</strong> Give everyone equal opportunity to connect</li>
              </ul>
              <p class="mt-3">Once a request is accepted, rejected, or cancelled, you can send a new one.</p>
            </div>
          </div>
        </div>

        <!-- CHATTING SECTION -->
        <div class="p-6 border-b border-t border-gray-100 bg-gray-50">
          <h2 class="text-xl font-bold text-gray-900 font-['Playfair_Display'] flex items-center">
            <i class="ri-chat-3-fill text-[#4a7c59] mr-2"></i>
            Chatting & Communication
          </h2>
        </div>

        <div class="divide-y divide-gray-100" data-category="chatting">
          <!-- FAQ Item 10 -->
          <div class="faq-item p-6" onclick="toggleFaq(this)">
            <div class="flex items-start justify-between">
              <h3 class="text-lg font-medium text-gray-900 pr-4">How do I start chatting with someone?</h3>
              <i class="ri-arrow-down-s-line faq-icon text-gray-400 text-xl flex-shrink-0"></i>
            </div>
            <div class="faq-answer text-gray-600">
              <p class="mb-3">To start chatting:</p>
              <ol class="list-decimal list-inside space-y-2 ml-2">
                <li>First, one of you must send an interest request</li>
                <li>The other person must accept the request</li>
                <li>Once accepted, a chat room is automatically created</li>
                <li>Go to <strong>"Chats"</strong> or <strong>"Inbox"</strong> in your account</li>
                <li>Click on the conversation to start messaging</li>
              </ol>
              <p class="mt-3 text-sm text-gray-500">
                <i class="ri-shield-check-line mr-1"></i>
                You cannot message someone without mutual consent (both parties accepting the connection).
              </p>
            </div>
          </div>

          <!-- FAQ Item 11 -->
          <div class="faq-item p-6" onclick="toggleFaq(this)">
            <div class="flex items-start justify-between">
              <h3 class="text-lg font-medium text-gray-900 pr-4">Are my chat messages private?</h3>
              <i class="ri-arrow-down-s-line faq-icon text-gray-400 text-xl flex-shrink-0"></i>
            </div>
            <div class="faq-answer text-gray-600">
              <p class="mb-3">Your conversations are private between you and the other person. However:</p>
              <ul class="list-disc list-inside space-y-2 ml-2">
                <li>Messages are stored securely on our servers</li>
                <li>Platform administrators may access chats for safety and moderation purposes</li>
                <li>This helps us prevent harassment, inappropriate behaviour, and ensure community safety</li>
              </ul>
              <p class="mt-3">We take privacy seriously and only review conversations when necessary for safety reasons.</p>
            </div>
          </div>

          <!-- FAQ Item 12 -->
          <div class="faq-item p-6" onclick="toggleFaq(this)">
            <div class="flex items-start justify-between">
              <h3 class="text-lg font-medium text-gray-900 pr-4">Will I be notified of new messages?</h3>
              <i class="ri-arrow-down-s-line faq-icon text-gray-400 text-xl flex-shrink-0"></i>
            </div>
            <div class="faq-answer text-gray-600">
              <p class="mb-3">Yes, we provide notifications to keep you updated:</p>
              <ul class="list-disc list-inside space-y-2 ml-2">
                <li><strong>On-site notifications:</strong> You'll see a badge indicator when you have unread messages</li>
                <li><strong>Email notifications:</strong> If enabled, you'll receive emails about new messages</li>
                <li>Real-time updates when you're online on the platform</li>
              </ul>
            </div>
          </div>
        </div>

        <!-- PROFILE SECTION -->
        <div class="p-6 border-b border-t border-gray-100 bg-gray-50">
          <h2 class="text-xl font-bold text-gray-900 font-['Playfair_Display'] flex items-center">
            <i class="ri-user-settings-fill text-[#4a7c59] mr-2"></i>
            Profile Management
          </h2>
        </div>

        <div class="divide-y divide-gray-100" data-category="profile">
          <!-- FAQ Item 13 -->
          <div class="faq-item p-6" onclick="toggleFaq(this)">
            <div class="flex items-start justify-between">
              <h3 class="text-lg font-medium text-gray-900 pr-4">How do I update my profile information?</h3>
              <i class="ri-arrow-down-s-line faq-icon text-gray-400 text-xl flex-shrink-0"></i>
            </div>
            <div class="faq-answer text-gray-600">
              <p class="mb-3">Updating your profile is easy:</p>
              <ol class="list-decimal list-inside space-y-2 ml-2">
                <li>Log in to your account</li>
                <li>Go to <strong>"Account"</strong> → <strong>"Profile Info"</strong> or visit <a href="/account/info" class="text-[#4a7c59] hover:underline">/account/info</a></li>
                <li>Edit any fields you wish to update</li>
                <li>Click <strong>"Save Changes"</strong></li>
              </ol>
              <p class="mt-3 text-sm text-gray-500">
                Some changes may require re-approval by our team to maintain profile quality.
              </p>
            </div>
          </div>

          <!-- FAQ Item 14 -->
          <div class="faq-item p-6" onclick="toggleFaq(this)">
            <div class="flex items-start justify-between">
              <h3 class="text-lg font-medium text-gray-900 pr-4">How do I change my profile photo?</h3>
              <i class="ri-arrow-down-s-line faq-icon text-gray-400 text-xl flex-shrink-0"></i>
            </div>
            <div class="faq-answer text-gray-600">
              <p class="mb-3">To change your profile photo:</p>
              <ol class="list-decimal list-inside space-y-2 ml-2">
                <li>Go to your account settings page</li>
                <li>Click on your current profile photo or the upload area</li>
                <li>Select a new image from your device</li>
                <li>The photo will be uploaded and optimised automatically</li>
              </ol>
              <div class="mt-4 p-3 bg-blue-50 rounded-lg">
                <p class="text-blue-800 text-sm">
                  <i class="ri-image-line mr-1"></i>
                  <strong>Photo Guidelines:</strong> Use a clear, recent photo. Avoid group photos. Ensure the image is appropriate and respectful according to Islamic guidelines.
                </p>
              </div>
            </div>
          </div>

          <!-- FAQ Item 15 -->
          <div class="faq-item p-6" onclick="toggleFaq(this)">
            <div class="flex items-start justify-between">
              <h3 class="text-lg font-medium text-gray-900 pr-4">How do I delete my account?</h3>
              <i class="ri-arrow-down-s-line faq-icon text-gray-400 text-xl flex-shrink-0"></i>
            </div>
            <div class="faq-answer text-gray-600">
              <p class="mb-3">To permanently delete your account:</p>
              <ol class="list-decimal list-inside space-y-2 ml-2">
                <li>Send an email to <a href="mailto:contact@damourmuslim.com" class="text-[#4a7c59] hover:underline">contact@damourmuslim.com</a></li>
                <li>Use the subject line: <strong>"Account Deletion Request"</strong></li>
                <li>Include your registered email address in the message</li>
                <li>Our team will process your request and confirm deletion</li>
              </ol>
              <div class="mt-4 p-3 bg-red-50 rounded-lg">
                <p class="text-red-800 text-sm">
                  <i class="ri-alert-line mr-1"></i>
                  <strong>Warning:</strong> Account deletion is permanent. All your data, conversations, and connections will be removed and cannot be recovered.
                </p>
              </div>
            </div>
          </div>

          <!-- FAQ Item 16 -->
          <div class="faq-item p-6" onclick="toggleFaq(this)">
            <div class="flex items-start justify-between">
              <h3 class="text-lg font-medium text-gray-900 pr-4">I forgot my password. How do I reset it?</h3>
              <i class="ri-arrow-down-s-line faq-icon text-gray-400 text-xl flex-shrink-0"></i>
            </div>
            <div class="faq-answer text-gray-600">
              <p class="mb-3">To reset your password:</p>
              <ol class="list-decimal list-inside space-y-2 ml-2">
                <li>Go to the <a href="/login" class="text-[#4a7c59] hover:underline">login page</a></li>
                <li>Click on <strong>"Forgot Password?"</strong></li>
                <li>Enter your registered email address</li>
                <li>Check your email for a password reset link</li>
                <li>Click the link and create a new password</li>
              </ol>
              <p class="mt-3 text-sm text-gray-500">
                The reset link expires after a limited time for security purposes. If it expires, simply request another one.
              </p>
            </div>
          </div>
        </div>

        <!-- MEMBERSHIP SECTION -->
        <div class="p-6 border-b border-t border-gray-100 bg-gray-50">
          <h2 class="text-xl font-bold text-gray-900 font-['Playfair_Display'] flex items-center">
            <i class="ri-vip-crown-fill text-[#4a7c59] mr-2"></i>
            Membership & Pricing
          </h2>
        </div>

        <div class="divide-y divide-gray-100" data-category="membership">
          <!-- FAQ Item 17 -->
          <div class="faq-item p-6" onclick="toggleFaq(this)">
            <div class="flex items-start justify-between">
              <h3 class="text-lg font-medium text-gray-900 pr-4">Is D'amour Muslim free to use?</h3>
              <i class="ri-arrow-down-s-line faq-icon text-gray-400 text-xl flex-shrink-0"></i>
            </div>
            <div class="faq-answer text-gray-600">
              <p class="mb-3">Yes! Our Standard plan is completely free:</p>
              <ul class="list-disc list-inside space-y-2 ml-2">
                <li>Create and manage your profile</li>
                <li>Browse all profiles on the platform</li>
                <li>Access WhatsApp groups for additional exposure</li>
                <li>Send and receive interest requests</li>
